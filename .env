# ── Setup Configuration (fill these in before running setup.sh) ──

GITHUB_ORG_REPO=VishnuPriyan-Meyi/learning-frontend-repository                  # e.g. myorg/learning-frontend-repository
GITHUB_BRANCH=main                         # branch to watch for deployments
BUCKET_NAME=react-dev-frontend-bucket       # globally unique S3 name for your React app
INFRA_STACK_NAME=frontend-infra            # CloudFormation stack name for S3 + CloudFront
PIPELINE_STACK_NAME=react-dev-frontend-pipeline      # CloudFormation stack name for the pipeline
AWS_REGION=us-east-1                       # your AWS region
GITHUB_CONNECTION_ARN=arn:aws:codeconnections:us-east-1:369606757523:connection/f2bea9f7-7d24-488f-a22f-dd79bc071c10     # ARN of a manually created AVAILABLE CodeStar connection
                                           

# ── Auto-filled by setup.sh (do not edit manually) ──

S3_BUCKET=react-dev-frontend-bucket
CLOUDFRONT_DISTRIBUTION=E24XANZNJBNRKT